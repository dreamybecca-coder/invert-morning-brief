# morning-brief · 环境变量模板
# 复制此文件为 .env 并填入真实值

# ── LLM API（二选一）────────────────────────────
KIMI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx

# ── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_INVEST_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_AI_CHAT_ID=-100xxxxxxxxxx

# ── Obsidian ─────────────────────────────────────
# macOS 示例：
OBSIDIAN_VAULT_PATH=/Users/rebecca/Library/Mobile Documents/iCloud~md~obsidian/Documents/YourVault
# 或绝对路径：
# OBSIDIAN_VAULT_PATH=/Users/rebecca/obsidian-vault

# ── 可选：付费源 Cookie ──────────────────────────
# THE_INFORMATION_COOKIE=
# SEMIANALYSIS_COOKIE=

# ── 运行参数 ─────────────────────────────────────
BRIEF_LOOKBACK_HOURS=24
BRIEF_MAX_INVEST=10
BRIEF_MAX_AI=10
LOG_LEVEL=INFO
